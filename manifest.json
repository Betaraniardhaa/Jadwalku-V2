{
  "id": "./",
  "name": "Jadwalku – Asisten Kampus & Kerja",
  "short_name": "Jadwalku",
  "description": "Aplikasi pencatat tugas kuliah, jadwal kuliah, dan jadwal kerja. Kelola deadline, jadwal, dan produktivitasmu dalam satu tempat.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "tabbed", "standalone"],
  "background_color": "#f8f5ff",
  "theme_color": "#e879a0",
  "orientation": "portrait",
  "lang": "id",
  "icons": [
    {
      "src": "icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "screenshots": [
    {
      "src": "icons/screenshot1.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow"
    }
  ],
  "shortcuts": [
    {
      "name": "Tambah Tugas",
      "short_name": "Tugas",
      "url": "./index.html#tugas",
      "icons": [{ "src": "icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Jadwal Kuliah",
      "short_name": "Kuliah",
      "url": "./index.html#kuliah",
      "icons": [{ "src": "icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Jadwal Kerja",
      "short_name": "Kerja",
      "url": "./index.html#kerja",
      "icons": [{ "src": "icons/icon-192.png", "sizes": "192x192" }]
    }
  ],
  "categories": ["education", "productivity", "utilities"],

  "launch_handler": {
    "client_mode": "focus-existing"
  },

  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "text/plain": [".txt"],
        "text/csv": [".csv"]
      },
      "icons": [{ "src": "icons/icon-192.png", "sizes": "192x192" }],
      "launch_type": "single-client"
    }
  ],

  "protocol_handlers": [
    {
      "protocol": "web+jadwalku",
      "url": "./index.html?url=%s"
    }
  ],

  "share_target": {
    "action": "./index.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },

  "edge_side_panel": {
    "preferred_width": 400
  },

  "note_taking": {
    "new_note_url": "./index.html#tugas"
  },

  "widgets": [
    {
      "name": "Jadwalku Widget",
      "tag": "jadwalku-widget",
      "url": "./index.html",
      "type": "text/html",
      "multiple": false,
      "icons": [
        { "src": "icons/icon-192.png", "sizes": "192x192", "type": "image/png" }
      ],
      "screenshots": [],
      "auth": false,
      "update": 3600
    }
  ]
}
